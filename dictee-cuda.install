# Arch install hook for dictee-cuda. Mirrors the postinst .deb / %post .rpm
# behaviour: creates two pip venvs (text2num for postprocess, nvidia-*-cu12
# for CUDA runtime libs), symlinks the NVIDIA .so files into /usr/lib/dictee/
# so ldconfig + ORT_DYLIB_PATH pick them up, and runs ldconfig.

_install_uinput_drop_in() {
    # The AUR `dotool` package ships /usr/lib/udev/rules.d/80-dotool.rules
    # with MODE="0620" (write-only for the input group). python-evdev opens
    # /dev/uinput with O_RDWR, which fails with that mode → dictee-ptt
    # crashes with "could not open uinput device in write mode" and the
    # PTT shortcut silently doesn't work. Drop a higher-priority override
    # in /etc/ (overrides /usr/lib/, survives pacman -S dotool upgrades).
    DROP_IN="/etc/udev/rules.d/81-dictee-uinput.rules"
    cat > "$DROP_IN" <<'RULES'
# Drop-in installed by dictee-cuda. Overrides MODE from /usr/lib/udev/rules.d/80-dotool.rules.
# python-evdev (used by dictee-ptt) opens /dev/uinput with O_RDWR, so we need
# read+write for the input group, not just write (0620).
KERNEL=="uinput", MODE="0660"
RULES
    udevadm control --reload-rules 2>/dev/null || true
    udevadm trigger --action=change /dev/uinput 2>/dev/null || true
}

_setup_user_groups() {
    # Add logged-in users to the 'input' group (dotool / dictee-ptt
    # need /dev/uinput access) and 'docker' group when docker is
    # available (LibreTranslate runs in Docker). Mirrors postinst .deb
    # and %post .rpm so an Arch user gets the same default behaviour
    # as Debian/Ubuntu/Fedora installs.
    for uid in $(loginctl list-sessions --no-legend 2>/dev/null | awk '{print $2}' | sort -u); do
        user=$(id -nu "$uid" 2>/dev/null) || continue
        [ "$user" = "root" ] && continue
        if ! id -nG "$user" | grep -qw input; then
            usermod -aG input "$user"
            echo "✓ $user added to group 'input' (dotool / PTT)"
        fi
        if command -v docker >/dev/null 2>&1; then
            if ! id -nG "$user" | grep -qw docker; then
                usermod -aG docker "$user"
                echo "✓ $user added to group 'docker' (LibreTranslate)"
            fi
        fi
    done
}

_install_postprocess_venv() {
    PP_VENV="/usr/share/dictee/postprocess-env"
    if command -v python3 >/dev/null 2>&1; then
        if [ ! -d "$PP_VENV" ]; then
            if python3 -m venv "$PP_VENV" 2>/dev/null; then
                "$PP_VENV/bin/pip" install --quiet --upgrade pip 2>/dev/null || true
                "$PP_VENV/bin/pip" install --quiet text2num 2>/dev/null || \
                    echo "Warning: text2num install failed (check internet)"
            fi
        fi
    fi
}

_upgrade_postprocess_venv() {
    PP_VENV="/usr/share/dictee/postprocess-env"
    if [ -d "$PP_VENV" ] && command -v python3 >/dev/null 2>&1; then
        "$PP_VENV/bin/pip" install --quiet --upgrade pip 2>/dev/null || true
        "$PP_VENV/bin/pip" install --quiet --upgrade text2num 2>/dev/null || true
    else
        _install_postprocess_venv
    fi
}

_install_cuda_venv() {
    if [ ! -f /usr/lib/dictee/libonnxruntime_providers_cuda.so ]; then
        return 0
    fi
    if ! command -v python3 >/dev/null 2>&1; then
        return 0
    fi
    CUDA_VENV="/opt/dictee/cuda-venv"
    mkdir -p /opt/dictee
    if [ ! -x "$CUDA_VENV/bin/pip" ]; then
        if ! python3 -m venv "$CUDA_VENV" 2>/dev/null; then
            echo "Warning: python3 -m venv failed for $CUDA_VENV — install python."
            return 0
        fi
        "$CUDA_VENV/bin/pip" install --quiet --upgrade pip 2>/dev/null || true
    fi
    echo "→ Downloading NVIDIA CUDA libs (~1.5 GB, may take a few minutes)..."
    if "$CUDA_VENV/bin/pip" install --quiet --upgrade \
            nvidia-cuda-runtime-cu12 \
            nvidia-cublas-cu12 \
            nvidia-cudnn-cu12 \
            nvidia-cufft-cu12 \
            nvidia-curand-cu12 \
            nvidia-cuda-nvrtc-cu12 2>/dev/null; then
        _py_ver=$(ls "$CUDA_VENV/lib/" 2>/dev/null | grep -E "^python" | head -1)
        if [ -n "$_py_ver" ]; then
            _nvidia_root="$CUDA_VENV/lib/$_py_ver/site-packages/nvidia"
            _count=0
            for _sub in "$_nvidia_root"/*/lib; do
                [ -d "$_sub" ] || continue
                for _so in "$_sub"/lib*.so*; do
                    [ -f "$_so" ] || continue
                    ln -sf "$_so" "/usr/lib/dictee/$(basename "$_so")"
                    _count=$((_count + 1))
                done
            done
            echo "✓ $_count NVIDIA libs linked into /usr/lib/dictee/"
        fi
    else
        echo "Warning: pip install of nvidia-*-cu12 failed (offline? disk full?)"
        echo "  Re-run later: sudo $CUDA_VENV/bin/pip install nvidia-cuda-runtime-cu12 nvidia-cublas-cu12 nvidia-cudnn-cu12 nvidia-cufft-cu12 nvidia-curand-cu12 nvidia-cuda-nvrtc-cu12 && sudo ldconfig"
    fi
    ldconfig 2>/dev/null || true
}

post_install() {
    # Load uinput now so dotool & dictee-ptt work without a reboot.
    # /etc/modules-load.d/dictee-uinput.conf handles subsequent boots.
    modprobe uinput 2>/dev/null || true

    _install_uinput_drop_in
    _setup_user_groups
    _install_postprocess_venv
    _install_cuda_venv
}

post_upgrade() {
    modprobe uinput 2>/dev/null || true

    _install_uinput_drop_in
    _setup_user_groups
    _upgrade_postprocess_venv
    _install_cuda_venv
}

pre_remove() {
    rm -rf /usr/share/dictee/postprocess-env
    rm -rf /opt/dictee/cuda-venv
    rmdir /opt/dictee 2>/dev/null || true
    rm -f /etc/udev/rules.d/81-dictee-uinput.rules
}
