# Helpers
# ---------------------------------------------------------------------------

def _singleton_path():
    return f"/tmp/dictee-meeting-live-{os.getuid()}.sock"


def meeting_dir(timestamp=None):
    base_dir = os.environ.get("DICTEE_MEETING_DIR",
                              os.path.join(os.path.expanduser("~"),
                                           ".local/share/dictee/meetings"))
    ts = timestamp or datetime.now().strftime("%Y-%m-%d-%H%M")
    base = Path(base_dir) / ts
    base.mkdir(parents=True, exist_ok=True)
    return base


def _build_subprocess_env():
    """Returns os.environ + ORT_DYLIB_PATH + all DICTEE_* keys from
    ~/.config/dictee.conf. Used for Rust binaries that need to see
    DICTEE_FORCE_CPU and friends.
    """
    env = os.environ.copy()
    ort_lib = "/usr/lib/dictee/libonnxruntime.so"
    if os.path.isfile(ort_lib):
        env["ORT_DYLIB_PATH"] = ort_lib
    conf_path = Path.home() / ".config/dictee.conf"
    if conf_path.is_file():
        try:
            for line in conf_path.read_text(encoding="utf-8").splitlines():
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                k, v = line.split("=", 1)
                k = k.strip()
                if k.startswith("DICTEE_"):
                    env[k] = v.strip().strip('"').strip("'")
        except OSError:
            pass
    return env


