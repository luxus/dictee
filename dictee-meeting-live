#!/usr/bin/env python3
"""dictee-meeting-live — Capture audio for a live meeting, then hand off to dictee-transcribe.

Captures audio with pw-record into audio.wav until the user clicks Stop, then
launches `dictee-transcribe --file <audio.wav> --diarize` which handles
transcription + diarization + LLM analysis + export.
"""

import json
import os
import sys
import argparse
import subprocess
from pathlib import Path
from datetime import datetime

from PyQt6.QtCore import QObject, QThread, pyqtSignal, QTimer
from PyQt6.QtWidgets import (
    QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
    QLabel, QPushButton,
)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _singleton_path():
    return f"/tmp/dictee-meeting-live-{os.getuid()}.sock"


def meeting_dir(timestamp=None):
    base_dir = os.environ.get("DICTEE_MEETING_DIR",
                              os.path.join(os.path.expanduser("~"),
                                           ".local/share/dictee/meetings"))
    ts = timestamp or datetime.now().strftime("%Y-%m-%d-%H%M")
    base = Path(base_dir) / ts
    base.mkdir(parents=True, exist_ok=True)
    return base


# ---------------------------------------------------------------------------
# Workers
# ---------------------------------------------------------------------------

class AudioCaptureWorker(QThread):
    """Continuous audio capture via pw-record into a growing WAV file."""

    error = pyqtSignal(str)

    def __init__(self, output_wav: Path):
        super().__init__()
        self.output_wav = output_wav
        self.proc = None
        self._stop = False

    def run(self):
        cmd = [
            "pw-record",
            "--format=s16",
            "--rate=16000",
            "--channels=1",
            "--target=@DEFAULT_AUDIO_SOURCE@",
            str(self.output_wav),
        ]
        try:
            self.proc = subprocess.Popen(
                cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE,
            )
            rc = self.proc.wait()
            if rc != 0 and not self._stop:
                err = self.proc.stderr.read().decode("utf-8", "replace")
                self.error.emit(f"pw-record exit {rc}: {err}")
        except FileNotFoundError:
            self.error.emit("pw-record not found. Is PipeWire installed?")

    def stop(self):
        self._stop = True
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()
            try:
                self.proc.wait(timeout=3)
            except subprocess.TimeoutExpired:
                self.proc.kill()


# ---------------------------------------------------------------------------
# Main window
# ---------------------------------------------------------------------------

class MeetingWindow(QMainWindow):
    """Minimal meeting capture window.

    Captures audio with pw-record until the user clicks Stop, then launches
    `dictee-transcribe --file <audio.wav> --diarize` to open the familiar
    transcription window for diarization + LLM analysis + export.
    """

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Réunion live — capture")
        self.resize(420, 180)

        self.audio_worker = None
        self.meeting_dir = None
        self.audio_wav = None
        self.elapsed_seconds = 0

        self._tick_timer = QTimer(self)
        self._tick_timer.timeout.connect(self._tick)
        self._tick_timer.setInterval(1000)

        self._build_ui()

    def _build_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        layout = QVBoxLayout(central)

        self.status_label = QLabel("Prêt à enregistrer")
        self.status_label.setStyleSheet("font-size: 14pt; padding: 12px;")
        layout.addWidget(self.status_label)

        self.duration_label = QLabel("00:00")
        self.duration_label.setStyleSheet("font-size: 24pt; font-family: monospace; padding: 8px;")
        layout.addWidget(self.duration_label)

        btn_row = QHBoxLayout()
        self.btn_start = QPushButton("▶ Démarrer")
        self.btn_start.clicked.connect(self.start_meeting)
        btn_row.addWidget(self.btn_start)

        self.btn_stop = QPushButton("⏹ Arrêter et analyser")
        self.btn_stop.clicked.connect(self.stop_meeting)
        self.btn_stop.setEnabled(False)
        btn_row.addWidget(self.btn_stop)

        layout.addLayout(btn_row)

    def start_meeting(self):
        self.meeting_dir = meeting_dir()
        self.audio_wav = self.meeting_dir / "audio.wav"

        # PTT mutex
        try:
            Path("/dev/shm/.dictee_state").write_text("meeting-recording\n")
        except OSError:
            pass

        self.elapsed_seconds = 0

        self.audio_worker = AudioCaptureWorker(self.audio_wav)
        self.audio_worker.error.connect(self._on_error_msg)
        self.audio_worker.start()

        self.btn_start.setEnabled(False)
        self.btn_stop.setEnabled(True)
        self.status_label.setText("● Enregistrement en cours")
        self._tick_timer.start()

    def stop_meeting(self):
        self._tick_timer.stop()
        if self.audio_worker:
            self.audio_worker.stop()
            self.audio_worker = None

        # Reset PTT mutex
        try:
            Path("/dev/shm/.dictee_state").write_text("idle\n")
        except OSError:
            pass

        # Write meeting metadata
        try:
            audio_size = self.audio_wav.stat().st_size if self.audio_wav else 0
        except FileNotFoundError:
            audio_size = 0
        meta = {
            "ended_at": datetime.now().isoformat(),
            "duration_s": self.elapsed_seconds,
            "audio_bytes": audio_size,
        }
        try:
            (self.meeting_dir / "meeting.meta.json").write_text(
                json.dumps(meta, indent=2, ensure_ascii=False),
                encoding="utf-8",
            )
        except (OSError, AttributeError):
            pass

        self.btn_start.setEnabled(True)
        self.btn_stop.setEnabled(False)

        # Sanity check on audio
        if audio_size < 1024:
            self.status_label.setText(f"Enregistrement trop court ({self.elapsed_seconds}s)")
            return

        self.status_label.setText("Ouverture de l'analyse...")

        # Hand off to dictee-transcribe with --diarize
        try:
            subprocess.Popen(
                ["dictee-transcribe", "--file", str(self.audio_wav), "--diarize"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except FileNotFoundError:
            self.status_label.setText("Erreur : dictee-transcribe introuvable")
            return

        # Close this window — dictee-transcribe takes over
        self.close()

    def _tick(self):
        self.elapsed_seconds += 1
        m, s = divmod(self.elapsed_seconds, 60)
        h, m = divmod(m, 60)
        if h > 0:
            self.duration_label.setText(f"{h:02d}:{m:02d}:{s:02d}")
        else:
            self.duration_label.setText(f"{m:02d}:{s:02d}")

    def _on_error_msg(self, msg: str):
        self.status_label.setText(f"Erreur : {msg}")
        print(f"[meeting-live] {msg}", file=sys.stderr)

    def closeEvent(self, event):
        if self.btn_stop.isEnabled():
            # Capture still running — stop it cleanly
            self._tick_timer.stop()
            if self.audio_worker:
                self.audio_worker.stop()
            try:
                Path("/dev/shm/.dictee_state").write_text("idle\n")
            except OSError:
                pass
        super().closeEvent(event)


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="Live meeting capture for dictee")
    parser.add_argument("--start", action="store_true", help="Start capture immediately")
    parser.add_argument("--stop", action="store_true", help="Stop running meeting")
    args = parser.parse_args()

    sock_path = _singleton_path()
    if os.path.exists(sock_path):
        print("[meeting-live] already running", file=sys.stderr)
        sys.exit(1)

    app = QApplication(sys.argv)
    win = MeetingWindow()
    win.show()
    if args.start:
        win.start_meeting()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
