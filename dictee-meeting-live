class AudioCaptureWorker(QThread):
    """Continuous audio capture via pw-record into a growing WAV file."""

    error = pyqtSignal(str)
    started_ok = pyqtSignal()

    def __init__(self, output_wav: Path):
        super().__init__()
        self.output_wav = output_wav
        self.proc = None
        self._stop = False

    def run(self):
        cmd = [
            "pw-record",
            "--format=s16",
            "--rate=16000",
            "--channels=1",
            "--target=@DEFAULT_AUDIO_SOURCE@",
            str(self.output_wav),
        ]
        try:
            self.proc = subprocess.Popen(
                cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE,
            )
            self.started_ok.emit()
            rc = self.proc.wait()
            if rc != 0 and not self._stop:
                err = self.proc.stderr.read().decode("utf-8", "replace")
                self.error.emit(f"pw-record exit {rc}: {err}")
        except FileNotFoundError:
            self.error.emit("pw-record not found. Is PipeWire installed?")

    def stop(self):
        self._stop = True
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()
            try:
                self.proc.wait(timeout=3)
            except subprocess.TimeoutExpired:
                self.proc.kill()


class ChunkerWorker(QThread):
    """Splits the growing audio.wav into 40 s chunks with 10 s overlap via ffmpeg.

    Emits `chunk_ready(int chunk_id, str path)` once each chunk is extracted.
    Strategy: poll every 1 s; once duration >= start_t + 40 s, extract
    [start_t, start_t+40] into chunk_NNN.wav and advance start_t by 30 s.
    """

    chunk_ready = pyqtSignal(int, str)
    error = pyqtSignal(str)

    def __init__(self, audio_wav: Path, chunks_dir: Path,
                 chunk_duration: int = 40, overlap: int = 10):
        super().__init__()
        self.audio_wav = audio_wav
        self.chunks_dir = chunks_dir
        self.chunk_duration = chunk_duration
        self.overlap = overlap
        self.advance = chunk_duration - overlap  # 30 s
        self._stop = False
        self.chunk_id = 0

    def run(self):
        self.chunks_dir.mkdir(parents=True, exist_ok=True)
        start_t = 0
        while not self._stop:
            duration = self._wav_duration(self.audio_wav)
            if duration >= start_t + self.chunk_duration:
                chunk_path = self.chunks_dir / f"chunk_{self.chunk_id:04d}.wav"
                rc = self._extract(start_t, self.chunk_duration, chunk_path)
                if rc == 0:
                    self.chunk_ready.emit(self.chunk_id, str(chunk_path))
                    self.chunk_id += 1
                    start_t += self.advance
                else:
                    self.error.emit(f"ffmpeg extract failed (chunk {self.chunk_id})")
                    return
            time.sleep(1)

    def _wav_duration(self, path: Path) -> float:
        # 44 byte header + raw PCM s16le mono 16 kHz = 32000 B/s
        try:
            size = path.stat().st_size
            return max(0.0, (size - 44) / 32000.0)
        except FileNotFoundError:
            return 0.0

    def _extract(self, start_s: int, dur_s: int, out_path: Path) -> int:
        cmd = [
            "ffmpeg", "-y",
            "-ss", str(start_s),
            "-t", str(dur_s),
            "-i", str(self.audio_wav),
            "-ar", "16000", "-ac", "1",
            "-c:a", "pcm_s16le",
            str(out_path),
        ]
        proc = subprocess.run(
            cmd,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return proc.returncode

    def stop(self):
        self._stop = True


class TranscriptionWorker(QObject):
    """Pour chaque chunk prêt, appelle transcribe-client et émet (chunk_id, tokens).

    tokens = [{"text": str, "start_s": float, "end_s": float}, ...]
    Utilise le transcribe-daemon existant (Parakeet INT8/FP32 déjà en RAM
    via le service systemd utilisateur).
    """

    transcribed = pyqtSignal(int, list)
    error = pyqtSignal(int, str)

    # Socket path mirrors transcribe-client SOCKET_PATH logic:
    # prefer $XDG_RUNTIME_DIR/transcribe.sock, fallback /tmp/transcribe.sock-<uid>
    def __init__(self):
        super().__init__()
        xdg = os.environ.get("XDG_RUNTIME_DIR")
        if xdg:
            self.daemon_socket = os.path.join(xdg, "transcribe.sock")
        else:
            self.daemon_socket = f"/tmp/transcribe.sock-{os.getuid()}"

    def transcribe(self, chunk_id: int, chunk_path: str):
        """Slot connecté à ChunkerWorker.chunk_ready."""
        if not os.path.exists(self.daemon_socket):
            self.error.emit(
                chunk_id,
                f"socket transcribe-daemon absente ({self.daemon_socket})",
            )
            return
        try:
            proc = subprocess.run(
                ["transcribe-client", chunk_path, "--json-timestamps"],
                capture_output=True,
                text=True,
                timeout=20,
            )
            if proc.returncode != 0:
                self.error.emit(
                    chunk_id,
                    f"transcribe-client exit {proc.returncode}: {proc.stderr.strip()}",
                )
                return
            data = json.loads(proc.stdout)
            tokens = data.get("tokens", [])
            self.transcribed.emit(chunk_id, tokens)
        except subprocess.TimeoutExpired:
            self.error.emit(chunk_id, "transcribe-client timeout (>20 s)")
        except json.JSONDecodeError as e:
            self.error.emit(chunk_id, f"JSON parse error: {e}")


class DiarizationWorker(QObject):
    """Keeps diarize-only --stream alive and sends chunks via stdin.

    Emits (chunk_id, segments) where segments = [{"start_s", "end_s", "speaker_id"}, ...]
    Sortformer state is preserved between chunks → stable speaker IDs.
    """

    diarized = pyqtSignal(int, list)
    error = pyqtSignal(int, str)

    def __init__(self, sortformer_dir: str = None):
        super().__init__()
        self.proc = None
        self.sortformer_dir = sortformer_dir

    def start(self) -> bool:
        """Launch the subprocess. Returns True if ready, False on failure."""
        cmd = ["diarize-only", "--stream"]
        if self.sortformer_dir:
            cmd += ["--sortformer-dir", self.sortformer_dir]
        try:
            self.proc = subprocess.Popen(
                cmd,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                bufsize=1,
            )
            # Wait for "ready" message on stderr (timeout 30s for slow CPU)
            deadline = time.monotonic() + 30
            while time.monotonic() < deadline:
                line = self.proc.stderr.readline()
                if not line:
                    self.error.emit(0, "diarize-only --stream stderr EOF before ready")
                    return False
                if "ready" in line:
                    return True
            self.error.emit(0, "diarize-only --stream startup timeout (30s)")
            return False
        except FileNotFoundError:
            self.error.emit(0, "diarize-only binary not found. Sortformer feature built?")
            return False

    def diarize(self, chunk_id: int, chunk_path: str):
        """Slot: process one chunk. Emits diarized(chunk_id, segments) when done."""
        if not self.proc:
            self.error.emit(chunk_id, "DiarizationWorker not started")
            return
        if self.proc.poll() is not None:
            self.error.emit(chunk_id, f"diarize-only exited with code {self.proc.returncode}")
            return
        try:
            self.proc.stdin.write(f"FILE: {chunk_path}\n")
            self.proc.stdin.flush()
            self._collect_response(chunk_id)
        except BrokenPipeError:
            self.error.emit(chunk_id, "diarize-only stdin pipe broken")

    def _collect_response(self, chunk_id: int):
        segments = []
        while True:
            line = self.proc.stdout.readline()
            if not line:
                self.error.emit(chunk_id, "diarize-only stdout EOF unexpected")
                return
            line = line.rstrip("\n")
            if line == "":
                # blank line = end of chunk
                self.diarized.emit(chunk_id, segments)
                return
            if line.startswith("ERROR:"):
                self.error.emit(chunk_id, line)
                return
            parts = line.split()
            if len(parts) == 3:
                try:
                    segments.append({
                        "start_s": float(parts[0]),
                        "end_s": float(parts[1]),
                        "speaker_id": int(parts[2]),
                    })
                except ValueError:
                    self.error.emit(chunk_id, f"malformed segment line: {line}")
                    return

    def reset_session(self):
        """Send RESET command to reset Sortformer streaming state."""
        if not self.proc or self.proc.poll() is not None:
            return
        try:
            self.proc.stdin.write("RESET\n")
            self.proc.stdin.flush()
            # Wait for RESET_OK
            deadline = time.monotonic() + 5
            while time.monotonic() < deadline:
                line = self.proc.stdout.readline()
                if not line:
                    return
                if line.strip() == "RESET_OK":
                    return
        except BrokenPipeError:
            pass

    def stop(self):
        if self.proc:
            try:
                if self.proc.stdin and not self.proc.stdin.closed:
                    self.proc.stdin.close()
                self.proc.wait(timeout=5)
            except (subprocess.TimeoutExpired, BrokenPipeError):
                self.proc.kill()
                self.proc.wait()
            self.proc = None


class AlignerWorker(QObject):
    """Aligns Parakeet tokens with Sortformer segments by timestamp overlap.

    For each token, picks the speaker with maximum overlap on [token.start_s, token.end_s].
    Consecutive tokens with the same speaker are grouped into one line.
    Local chunk timestamps are offset to absolute meeting timestamps via chunk_offset_s.

    Logic ported from src/bin/transcribe_diarize_batch.rs:316-343.

    Emits aligned(chunk_id, lines) where:
      lines = [{"speaker": int, "text": str, "start_s": float, "end_s": float}, ...]
    """

    aligned = pyqtSignal(int, list)

    def __init__(self, chunk_offset_s: dict = None):
        super().__init__()
        # chunk_id → absolute offset in seconds (set by orchestrator before each chunk)
        self.chunk_offset = chunk_offset_s or {}
        # Pending results: both tokens and segments must arrive before alignment
        self._transcription = {}  # chunk_id → tokens
        self._diarization = {}    # chunk_id → segments

    def on_transcribed(self, chunk_id: int, tokens: list):
        """Slot for TranscriptionWorker.transcribed signal."""
        self._transcription[chunk_id] = tokens
        self._try_align(chunk_id)

    def on_diarized(self, chunk_id: int, segments: list):
        """Slot for DiarizationWorker.diarized signal."""
        self._diarization[chunk_id] = segments
        self._try_align(chunk_id)

    def _try_align(self, chunk_id: int):
        if chunk_id not in self._transcription or chunk_id not in self._diarization:
            return
        tokens = self._transcription.pop(chunk_id)
        segments = self._diarization.pop(chunk_id)
        offset = self.chunk_offset.get(chunk_id, 0.0)

        lines = []
        current_speaker = None
        current_text = []
        current_start = None
        current_end = None

        for tok in tokens:
            spk = self._find_speaker(tok["start_s"], tok["end_s"], segments)
            if spk != current_speaker:
                if current_speaker is not None:
                    lines.append({
                        "speaker": current_speaker,
                        "text": " ".join(current_text).strip(),
                        "start_s": current_start + offset,
                        "end_s": current_end + offset,
                    })
                current_speaker = spk
                current_text = [tok["text"]]
                current_start = tok["start_s"]
            else:
                current_text.append(tok["text"])
            current_end = tok["end_s"]

        if current_speaker is not None:
            lines.append({
                "speaker": current_speaker,
                "text": " ".join(current_text).strip(),
                "start_s": current_start + offset,
                "end_s": current_end + offset,
            })

        self.aligned.emit(chunk_id, lines)

    @staticmethod
    def _find_speaker(tok_start: float, tok_end: float, segments: list) -> int:
        """Return the speaker_id with maximum overlap with [tok_start, tok_end].

        Returns -1 if no segment overlaps (silence or out-of-range token).
        """
        best_spk = -1
        best_overlap = 0.0
        for seg in segments:
            overlap = max(0.0, min(tok_end, seg["end_s"]) - max(tok_start, seg["start_s"]))
            if overlap > best_overlap:
                best_overlap = overlap
                best_spk = seg["speaker_id"]
        return best_spk


