class MeetingWindow(QMainWindow):
    """Minimal meeting capture window with collapsible live preview accordion.

    Captures audio with pw-record until the user clicks Stop, then launches
    `dictee-transcribe --file <audio.wav> --diarize` to open the familiar
    transcription window for diarization + LLM analysis + export.

    The live preview accordion streams chunk-by-chunk transcript during
    recording — it is a bonus preview only.
    """

    SPEAKER_COLORS = [
        "#1976D2",  # blue
        "#388E3C",  # green
        "#F57C00",  # orange
        "#C62828",  # red
    ]

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Réunion live — capture")
        self.resize(560, 220)

        self.audio_worker = None
        self.meeting_dir = None
        self.audio_wav = None
        self.transcript_path = None
        self.elapsed_seconds = 0
        self.speakers_seen = set()

        # Speaker naming (purely visual for live preview)
        self._speaker_name_map = {}      # {speaker_id: user_provided_name}
        self._speaker_row_widgets = {}   # {speaker_id: QLineEdit} for dynamic update

        self.chunker = None
        self.transcriber = None
        self.diarizer = None
        self.aligner = None

        self._tick_timer = QTimer(self)
        self._tick_timer.timeout.connect(self._tick)
        self._tick_timer.setInterval(1000)

        self._build_ui()
        self._apply_window_behavior()

        # Signal to plasmoid/tray that meeting-live UI is open
        try:
            Path("/dev/shm/.dictee_state").write_text("meeting-ui-open\n")
        except OSError:
            pass

    def _build_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        layout = QVBoxLayout(central)

        self.status_label = QLabel("Prêt à enregistrer")
        self.status_label.setStyleSheet("font-size: 14pt; padding: 12px;")
        layout.addWidget(self.status_label)

        self.duration_label = QLabel("00:00")
        self.duration_label.setStyleSheet("font-size: 24pt; font-family: monospace; padding: 8px;")
        layout.addWidget(self.duration_label)

        btn_row = QHBoxLayout()
        self.btn_start = QPushButton("▶ Démarrer")
        self.btn_start.clicked.connect(self.start_meeting)
        btn_row.addWidget(self.btn_start)

        self.btn_stop = QPushButton("⏹ Arrêter et analyser")
        self.btn_stop.clicked.connect(self.stop_meeting)
        self.btn_stop.setEnabled(False)
        btn_row.addWidget(self.btn_stop)

        layout.addLayout(btn_row)

        # Live preview accordion (clickable header + collapsible content)
        self.preview_toggle = QToolButton()
        self.preview_toggle.setText("Aperçu en direct")
        self.preview_toggle.setCheckable(True)
        self.preview_toggle.setChecked(False)
        self.preview_toggle.setArrowType(Qt.ArrowType.RightArrow)
        self.preview_toggle.setToolButtonStyle(Qt.ToolButtonStyle.ToolButtonTextBesideIcon)
        self.preview_toggle.setStyleSheet(
            "QToolButton { border: none; font-weight: bold; padding: 6px; text-align: left; }"
            "QToolButton:hover { background-color: rgba(0,0,0,0.05); }"
        )
        layout.addWidget(self.preview_toggle)

        self.preview_content = QFrame()
        self.preview_content.setFrameShape(QFrame.Shape.StyledPanel)
        preview_layout = QVBoxLayout(self.preview_content)
        preview_layout.setContentsMargins(4, 4, 4, 4)
        self.transcript_view = QTextEdit()
        self.transcript_view.setReadOnly(True)
        self.transcript_view.setStyleSheet("font-family: monospace; font-size: 10pt;")
        self.transcript_view.setMinimumHeight(180)
        preview_layout.addWidget(self.transcript_view)

        # Speakers naming panel (inside accordion, below transcript view)
        speakers_group = QGroupBox("Speakers détectés")
        speakers_group.setStyleSheet("QGroupBox { font-weight: bold; }")
        self._speakers_form = QFormLayout(speakers_group)
        self._speakers_form.setLabelAlignment(Qt.AlignmentFlag.AlignRight)
        # Empty by default — filled dynamically by _on_aligned
        preview_layout.addWidget(speakers_group)

        layout.addWidget(self.preview_content)

        self.preview_content.setVisible(False)
        self.preview_toggle.toggled.connect(self._on_preview_toggled)

    def _apply_window_behavior(self):
        """Apply always-on-top and all-virtual-desktops options from conf."""
        conf_path = Path.home() / ".config/dictee.conf"
        always_on_top = True   # default
        all_desktops = False   # default
        if conf_path.is_file():
            try:
                for line in conf_path.read_text(encoding="utf-8").splitlines():
                    line = line.strip()
                    if line.startswith("DICTEE_MEETING_ALWAYS_ON_TOP="):
                        v = line.split("=", 1)[1].strip().strip('"').strip("'").lower()
                        always_on_top = v in ("true", "1", "yes")
                    elif line.startswith("DICTEE_MEETING_ALL_DESKTOPS="):
                        v = line.split("=", 1)[1].strip().strip('"').strip("'").lower()
                        all_desktops = v in ("true", "1", "yes")
            except OSError:
                pass

        if always_on_top:
            self.setWindowFlag(Qt.WindowType.WindowStaysOnTopHint, True)

        if all_desktops:
            QTimer.singleShot(100, self._set_on_all_desktops)

    def _set_on_all_desktops(self):
        """Set the window visible on all virtual desktops.

        On X11: uses wmctrl (add,sticky).
        On Wayland/KDE: not yet supported — shows a notify-send notice.
        Silently no-ops on unsupported platforms.
        """
        try:
            win_id = int(self.winId())
        except Exception:
            return

        if os.environ.get("XDG_SESSION_TYPE", "") == "x11":
            try:
                subprocess.run(
                    ["wmctrl", "-i", "-r", str(win_id), "-b", "add,sticky"],
                    timeout=2, capture_output=True,
                )
                return
            except (FileNotFoundError, subprocess.TimeoutExpired):
                pass

        # Wayland: no reliable cross-compositor API without KWindowSystem (PyKF5).
        try:
            subprocess.run(
                ["notify-send", "-t", "5000",
                 "dictee-meeting-live",
                 "All desktops option not yet supported on Wayland — "
                 "window will only show on current desktop."],
                timeout=2, capture_output=True,
            )
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass

    def start_meeting(self):
        self.meeting_dir = meeting_dir()
        self.audio_wav = self.meeting_dir / "audio.wav"
        chunks_dir = self.meeting_dir / "chunks"
        self.transcript_path = self.meeting_dir / "transcript-live.md"

        # Init transcript markdown header
        self.transcript_path.write_text(
            f"# Réunion {datetime.now().strftime('%Y-%m-%d %H:%M')}\n\n",
            encoding="utf-8",
        )

        # PTT mutex
        try:
            Path("/dev/shm/.dictee_state").write_text("meeting-recording\n")
        except OSError:
            pass

        self.elapsed_seconds = 0

        # Reset speaker state for new meeting
        self._speaker_name_map.clear()
        for le in self._speaker_row_widgets.values():
            self._speakers_form.removeRow(le)
        self._speaker_row_widgets.clear()
        self.speakers_seen = set()

        # Audio capture
        self.audio_worker = AudioCaptureWorker(self.audio_wav)
        self.audio_worker.error.connect(self._on_error_msg)
        self.audio_worker.start()

        # Read chunk duration from conf (default 40s, range 20-60)
        chunk_duration = 40
        try:
            conf_path = Path.home() / ".config/dictee.conf"
            if conf_path.exists():
                for line in conf_path.read_text().splitlines():
                    if line.startswith("DICTEE_MEETING_CHUNK_S="):
                        val = line.split("=", 1)[1].strip().strip('"').strip("'")
                        chunk_duration = max(20, min(60, int(val)))
                        break
        except (OSError, ValueError):
            pass
        self.chunk_duration = chunk_duration

        # Workers for live preview
        self.chunker = ChunkerWorker(self.audio_wav, chunks_dir,
                                     chunk_duration=chunk_duration, overlap=10)
        self.chunker.chunk_ready.connect(self._on_chunk_ready)
        self.chunker.error.connect(self._on_error_msg)
        self.chunker.start()

        self.transcriber = TranscriptionWorker()
        self.diarizer = DiarizationWorker()
        if not self.diarizer.start():
            self._on_error_msg("Failed to start diarize-only --stream")

        self.aligner = AlignerWorker()
        self.aligner.chunk_offset = {}

        self.transcriber.transcribed.connect(self.aligner.on_transcribed)
        self.diarizer.diarized.connect(self.aligner.on_diarized)
        self.aligner.aligned.connect(self._on_aligned)
        self.transcriber.error.connect(self._on_chunk_error)
        self.diarizer.error.connect(self._on_chunk_error)

        # Background executor for blocking subprocess calls
        import concurrent.futures
        self._executor = concurrent.futures.ThreadPoolExecutor(max_workers=2)

        # File watcher for the preview view
        self.watcher = QFileSystemWatcher([str(self.transcript_path)])
        self.watcher.fileChanged.connect(self._reload_transcript)

        self.btn_start.setEnabled(False)
        self.btn_stop.setEnabled(True)
        self.status_label.setText("● Enregistrement en cours")
        self._tick_timer.start()

    def _on_chunk_ready(self, chunk_id: int, chunk_path: str):
        # Compute absolute offset for aligner: chunk N starts at N * advance
        self.aligner.chunk_offset[chunk_id] = chunk_id * (self.chunk_duration - 10)
        self._executor.submit(self.transcriber.transcribe, chunk_id, chunk_path)
        self._executor.submit(self.diarizer.diarize, chunk_id, chunk_path)

    def _on_aligned(self, chunk_id: int, lines: list):
        with open(self.transcript_path, "a", encoding="utf-8") as f:
            for ln in lines:
                spk = ln["speaker"]
                if spk == -1:
                    continue
                f.write(f"[{ln['start_s']:.3f}s - {ln['end_s']:.3f}s] Speaker {spk}: {ln['text']}\n")

                # NEW: if this is a brand-new speaker, add a naming row in the panel
                if spk not in self.speakers_seen:
                    self.speakers_seen.add(spk)
                    self._add_speaker_row(spk)

    def _add_speaker_row(self, spk_id: int):
        """Add a QLineEdit row for naming a newly detected speaker."""
        if spk_id in self._speaker_row_widgets:
            return
        label_text = f"Speaker {spk_id}"
        line_edit = QLineEdit()
        line_edit.setPlaceholderText("(nommer ce locuteur…)")
        line_edit.editingFinished.connect(
            lambda sid=spk_id, le=line_edit: self._on_speaker_renamed(sid, le.text().strip())
        )
        self._speakers_form.addRow(label_text, line_edit)
        self._speaker_row_widgets[spk_id] = line_edit

    def _on_speaker_renamed(self, spk_id: int, name: str):
        if name:
            self._speaker_name_map[spk_id] = name
        else:
            self._speaker_name_map.pop(spk_id, None)
        # Trigger transcript view re-render to reflect the new name
        self._reload_transcript()

    def _on_chunk_error(self, chunk_id: int, msg: str):
        print(f"[meeting-live] chunk {chunk_id}: {msg}", file=sys.stderr)

    def _reload_transcript(self):
        if not self.transcript_path:
            return
        spk_pattern = re.compile(
            r"^\[(\d+\.?\d*)s\s*-\s*(\d+\.?\d*)s\]\s*Speaker\s+(\d+):\s*(.*)$"
        )
        try:
            content = self.transcript_path.read_text(encoding="utf-8")
            html_lines = []
            for line in content.split("\n"):
                m = spk_pattern.match(line)
                if m:
                    start_s, _end_s, spk_id, text = m.groups()
                    spk_id = int(spk_id)
                    color = self.SPEAKER_COLORS[spk_id % len(self.SPEAKER_COLORS)]
                    t = self._fmt_time(float(start_s))
                    display_name = self._speaker_name_map.get(spk_id, f"Speaker {spk_id}")
                    html_lines.append(
                        f'<p style="color:{color}"><b>[{display_name}]</b> '
                        f'<span style="color:#888">({t})</span> {text}</p>'
                    )
                else:
                    html_lines.append(f"<p>{line}</p>")
            self.transcript_view.setHtml("\n".join(html_lines))
            sb = self.transcript_view.verticalScrollBar()
            sb.setValue(sb.maximum())
        except FileNotFoundError:
            pass

    @staticmethod
    def _fmt_time(seconds: float) -> str:
        m = int(seconds) // 60
        s = int(seconds) % 60
        return f"{m:02d}:{s:02d}"

    def _on_preview_toggled(self, checked: bool):
        self.preview_content.setVisible(checked)
        self.preview_toggle.setArrowType(
            Qt.ArrowType.DownArrow if checked else Qt.ArrowType.RightArrow
        )
        if checked:
            self.resize(self.width(), max(self.height(), 440))

    def _extract_speaker_anchors(self, min_duration_s: float = 1.5, max_anchors_per_speaker: int = 5) -> dict:
        """Parse transcript-live.md to extract temporal anchors per speaker_id.

        Returns {speaker_id: [{"start": float, "end": float}, ...]}
        Only keeps segments >= min_duration_s (filters short interjections).
        Sorted by duration descending, capped at max_anchors_per_speaker.
        """
        anchors = {}
        try:
            content = self.transcript_path.read_text(encoding="utf-8")
        except FileNotFoundError:
            return anchors
        line_re = re.compile(r"^\[(\d+\.?\d*)s\s*-\s*(\d+\.?\d*)s\]\s*Speaker\s+(\d+):")
        for line in content.splitlines():
            m = line_re.match(line)
            if not m:
                continue
            start = float(m.group(1))
            end = float(m.group(2))
            spk_id = int(m.group(3))
            duration = end - start
            if duration < min_duration_s:
                continue
            anchors.setdefault(spk_id, []).append({"start": start, "end": end})
        # Sort by duration desc, keep top N per speaker
        for spk_id in list(anchors.keys()):
            anchors[spk_id].sort(key=lambda a: a["end"] - a["start"], reverse=True)
            anchors[spk_id] = anchors[spk_id][:max_anchors_per_speaker]
        return anchors

    def stop_meeting(self):
        self._tick_timer.stop()

        # Stop audio first (freeze WAV)
        if self.audio_worker:
            self.audio_worker.stop()
            self.audio_worker = None

        # Stop live preview workers (best effort)
        if hasattr(self, "chunker") and self.chunker:
            self.chunker.stop()
        if hasattr(self, "diarizer") and self.diarizer:
            self.diarizer.stop()
        if hasattr(self, "_executor") and self._executor:
            self._executor.shutdown(wait=False)

        # Reset PTT mutex
        try:
            Path("/dev/shm/.dictee_state").write_text("idle\n")
        except OSError:
            pass

        # Write meeting metadata
        try:
            audio_size = self.audio_wav.stat().st_size if self.audio_wav else 0
        except FileNotFoundError:
            audio_size = 0
        meta = {
            "ended_at": datetime.now().isoformat(),
            "duration_s": self.elapsed_seconds,
            "audio_bytes": audio_size,
        }
        try:
            (self.meeting_dir / "meeting.meta.json").write_text(
                json.dumps(meta, indent=2, ensure_ascii=False),
                encoding="utf-8",
            )
        except (OSError, AttributeError):
            pass

        self.btn_start.setEnabled(True)
        self.btn_stop.setEnabled(False)

        # Sanity check audio
        if audio_size < 1024:
            self.status_label.setText(f"Enregistrement trop court ({self.elapsed_seconds}s)")
            return

        self.status_label.setText("Ouverture de l'analyse...")

        # Write speakers.json next to audio.wav so dictee-transcribe can
        # pre-fill the rename panel with live-session speaker names.
        if self._speaker_name_map and self.transcript_path and self.transcript_path.is_file():
            try:
                anchors = self._extract_speaker_anchors()
                speakers_data = {
                    "name_map": {str(k): v for k, v in self._speaker_name_map.items()},
                    "anchors": {
                        str(k): v for k, v in anchors.items()
                        if k in self._speaker_name_map  # only named speakers
                    },
                }
                speakers_json_path = self.meeting_dir / "speakers.json"
                speakers_json_path.write_text(
                    json.dumps(speakers_data, indent=2, ensure_ascii=False),
                    encoding="utf-8",
                )
            except Exception as e:
                print(f"[meeting-live] failed to write speakers.json: {e}", file=sys.stderr)

        # Hand off to dictee-transcribe
        try:
            subprocess.Popen(
                ["dictee-transcribe", "--file", str(self.audio_wav), "--diarize"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except FileNotFoundError:
            self.status_label.setText("Erreur : dictee-transcribe introuvable")
            return

        self.close()

    def _tick(self):
        self.elapsed_seconds += 1
        m, s = divmod(self.elapsed_seconds, 60)
        h, m = divmod(m, 60)
        if h > 0:
            self.duration_label.setText(f"{h:02d}:{m:02d}:{s:02d}")
        else:
            self.duration_label.setText(f"{m:02d}:{s:02d}")

    def _on_error_msg(self, msg: str):
        self.status_label.setText(f"Erreur : {msg}")
        print(f"[meeting-live] {msg}", file=sys.stderr)

    def closeEvent(self, event):
        if self.btn_stop.isEnabled():
            # Capture still running — stop it cleanly
            self._tick_timer.stop()
            if self.audio_worker:
                self.audio_worker.stop()
        # Reset state on window close (regardless of recording state)
        try:
            Path("/dev/shm/.dictee_state").write_text("idle\n")
        except OSError:
            pass
        super().closeEvent(event)


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="Live meeting capture for dictee")
    parser.add_argument("--start", action="store_true", help="Start capture immediately")
    parser.add_argument("--stop", action="store_true", help="Stop running meeting")
    args = parser.parse_args()

    sock_path = _singleton_path()
    if os.path.exists(sock_path):
        print("[meeting-live] already running", file=sys.stderr)
        sys.exit(1)

    app = QApplication(sys.argv)
    win = MeetingWindow()
    win.show()
    if args.start:
        win.start_meeting()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
