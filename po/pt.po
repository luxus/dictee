#: dictee-setup.py:1969
msgid ""
"Multilingual transcription (25 languages, ~2.5 GB) — best accuracy, "
"recommended for GPU"
msgstr ""

#: dictee-setup.py:1971
msgid ""
"<b>Parakeet-TDT 0.6B v3 — FP32</b><br><br>Full-precision variant of the main "
"transcription model.<br>FastConformer encoder + Token-and-Duration "
"Transducer (TDT) decoder.<br>Supports <b>25 languages</b> including French, "
"English, Spanish, German, etc.<br>Native punctuation and capitalization (no "
"post-processing needed).<br><br>Recommended for <b>GPU with ≥ 4 GB VRAM</b> "
"— fastest on CUDA Tensor Cores.<br>Used by: <code>transcribe</code>, "
"<code>transcribe-daemon</code>, <code>transcribe-diarize</code>, "
"<code>dictee</code>"
msgstr ""

#: dictee-setup.py:1994
msgid "Quantized variant (~670 MB) — recommended for CPU and low-VRAM GPU"
msgstr ""

#: dictee-setup.py:1996
#, python-format
msgid ""
"<b>Parakeet-TDT 0.6B v3 — int8 quantized</b><br><br>Same architecture as "
"FP32 with 8-bit quantized weights.<br><br><b>~3.6× smaller</b>: 670 MB on "
"disk / RAM (vs 2.4 GB FP32).<br><b>~38% faster on CPU</b> with AVX-VNNI "
"(Intel Cascade Lake+ / AMD Zen 2+).<br><b>WER loss negligible</b> (~0-1 "
"% depending on audio).<br><br>Recommended for: <b>CPU-only systems</b> or "
"<b>GPU with &lt; 4 GB VRAM</b>.<br>Note: on GPU with abundant VRAM, FP32 is "
"faster (CUDA int8 EP is slow)."
msgstr ""

#: dictee-setup.py:2017
msgid "Speaker diarization (4 speakers max, ~50 MB)"
msgstr "Diarização de locutores (máx. 4 locutores, ~50 MB)"

#: dictee-setup.py:2019
msgid ""
"<b>Sortformer</b> — Speaker diarization model<br><br>Identifies and "
"separates up to <b>4 different speakers</b> in an audio recording.<br>Labels "
"each transcription segment with the speaker who said it.<br><br><b>Optional</"
"b> — only needed if you want speaker identification.<br>Used by: "
"<code>transcribe-diarize</code>"
msgstr ""
"<b>Sortformer</b> — Modelo de diarização<br><br>Identifica e separa até <b>4 "
"locutores diferentes</b> numa gravação de áudio.<br>Associa cada segmento de "
"transcrição ao locutor correspondente.<br><br><b>Opcional</b> — necessário "
"apenas para identificação de locutores.<br>Usado por: <code>transcribe-"
"diarize</code>"

