"Exemple : \"le arbre\" → \"l'arbre\",\n"
"\"de eau\" → \"d'eau\""

#: dictee-setup.py:11413
msgid "Typography (non-breaking spaces)"
msgstr "Typographie (espaces insécables)"

#: dictee-setup.py:11416
msgid ""
"Inserts non-breaking spaces before French\n"
