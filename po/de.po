#: dictee-setup.py:11406
msgid "Elisions"
msgstr "Elisionen"

#: dictee-setup.py:11409
msgid ""
"Applies French elision rules.\n"
"Example: \"le arbre\" → \"l'arbre\",\n"
"\"de eau\" → \"d'eau\""
msgstr ""
